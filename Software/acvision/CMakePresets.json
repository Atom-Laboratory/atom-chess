{
    "version": 3,
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build",
            "cacheVariables": {
            "CMAKE_EXPORT_COMPILE_COMMANDS": true,
            "CMAKE_C_COMPILER": "cl",
            "CMAKE_CXX_COMPILER": "cl"
        }
        },
        {
            "name": "debug",
            "displayName": "Debug",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "OpenCV_DIR": "$env{OpenCV_DIR}"
            }
        },
        {
            "name": "release",
            "displayName": "Release",
            "inherits": "base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "OpenCV_DIR": "$env{OpenCV_DIR}"
            }
        }
    ]
}