<?xml version="1.0"?>
<robot name="atom_scara" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <material name="atom_blue">
        <color rgba="0.1 0.3 0.8 1.0"/>
    </material>

    <link name="world"/>

    <link name="base_link">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://atom_description/meshes/base.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="atom_blue"/>
        </visual>
    </link>

    <joint name="fixed_base" type="fixed">
        <parent link="world"/>
        <child link="base_link"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <link name="z_axis_link">
        <visual>
            <origin xyz="-0.04 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://atom_description/meshes/z_axis.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="atom_blue"/>
        </visual>
    </link>

    <joint name="joint_base_to_link1" type="revolute">
        <parent link="base_link"/>
        <child link="z_axis_link"/>

        <origin xyz="0.04 0 0" rpy="0 0 0"/>

        <axis xyz="0 1 0"/>

        <limit lower="-2.0" upper="2.0" effort="50.0" velocity="3.14"/>
    </joint>

    <link name="arm1_link">
        <visual>
            <origin xyz="-0.04 0 0" rpy="0 0 0"/> 
            <geometry>
                <mesh filename="package://atom_description/meshes/arm1.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="atom_blue"/>
        </visual>
    </link>

    <joint name="joint_z_axis_arm1" type="prismatic">
        <parent link="z_axis_link"/> 
        <child link="arm1_link"/>
        
        <origin xyz="0.0 0.0 0.0" rpy="0 0 0"/> 
        
        <axis xyz="0 1 0"/> 
        
        <limit lower="-0.1" upper="0.20" effort="50.0" velocity="0.5"/> 
    </joint>

    <link name="arm2_link">
        <visual>
            <origin xyz="-0.26 0 0" rpy="0 0 0"/>
            <geometry>
                <mesh filename="package://atom_description/meshes/arm2.stl" scale="0.001 0.001 0.001"/>
            </geometry>
            <material name="atom_blue"/>
        </visual>
    </link>

    <joint name="joint_arm1_link_arm2_link" type="revolute">
        <parent link="arm1_link"/>
        <child link="arm2_link"/>

        <origin xyz="0.22 0 0" rpy="0 0 0"/>

        <axis xyz="0 1 0"/>

        <limit lower="-2.0" upper="4.0" effort="50.0" velocity="3.14"/>
    </joint>

</robot>